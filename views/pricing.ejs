<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>InnovaShield – Pricing</title>
  <link rel="stylesheet" href="/style.css"/>
  <script>
    (function(){ 
      const t = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
  <style>
    .pricing-hero {
      text-align: center;
      padding: 80px 2rem 60px;
      position: relative;
    }
    .pricing-hero::before {
      content: '';
      position: absolute; top: -80px; left: 50%; transform: translateX(-50%);
      width: 700px; height: 500px;
      background: radial-gradient(ellipse, rgba(79,142,247,0.1) 0%, transparent 70%);
      pointer-events: none;
    }
    .pricing-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem; letter-spacing: 3px;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: 1rem; opacity: 0.85;
    }
    .pricing-hero h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 800; letter-spacing: -2px;
      margin-bottom: 1rem;
    }
    .pricing-hero h1 span {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .pricing-hero p {
      font-size: 1.05rem; color: var(--text-3);
      max-width: 500px; margin: 0 auto 1rem;
    }

    /* BILLING TOGGLE */
    .billing-toggle {
      display: inline-flex; align-items: center; gap: 0.75rem;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 20px; padding: 0.4rem 1rem;
      margin-bottom: 3rem; cursor: pointer;
    }
    .billing-toggle span { font-size: 0.88rem; color: var(--text-3); font-weight: 500; }
    .billing-toggle span.active { color: var(--text); font-weight: 600; }
    .toggle-switch {
      width: 44px; height: 24px; background: var(--accent);
      border-radius: 12px; position: relative; cursor: pointer;
      transition: background 0.2s;
    }
    .toggle-switch::after {
      content: '';
      position: absolute; top: 3px; left: 3px;
      width: 18px; height: 18px; border-radius: 50%;
      background: #fff; transition: transform 0.2s;
    }
    .toggle-switch.yearly::after { transform: translateX(20px); }

    .save-badge {
      background: rgba(52,211,153,0.15); color: var(--success);
      padding: 0.2rem 0.6rem; border-radius: 20px;
      font-size: 0.72rem; font-weight: 600;
    }

    /* PLANS GRID */
    .plans-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem; max-width: 1100px;
      margin: 0 auto 5rem; padding: 0 2rem;
    }

    .plan-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 20px; padding: 2rem;
      position: relative; overflow: hidden;
      transition: all 0.2s;
    }
    .plan-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.2); }

    .plan-card.popular {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px var(--accent), 0 8px 32px var(--accent-glow);
    }
    .plan-card.popular::before {
      content: 'Most Popular';
      position: absolute; top: 0; left: 50%; transform: translateX(-50%);
      background: var(--accent); color: #fff;
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.05em;
      padding: 0.3rem 1.2rem; border-radius: 0 0 10px 10px;
      text-transform: uppercase;
    }

    .plan-name {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1rem; font-weight: 700;
      color: var(--text-3); text-transform: uppercase;
      letter-spacing: 0.08em; margin-bottom: 1rem;
      margin-top: 1.5rem;
    }
    .plan-card.popular .plan-name { margin-top: 2rem; }

    .plan-price {
      display: flex; align-items: baseline; gap: 0.3rem;
      margin-bottom: 0.5rem;
    }
    .price-currency { font-size: 1.2rem; font-weight: 700; color: var(--text-2); margin-top: 0.4rem; }
    .price-amount {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 3.5rem; font-weight: 800;
      color: var(--text); letter-spacing: -3px; line-height: 1;
    }
    .price-period { font-size: 0.88rem; color: var(--text-3); }
    .price-annual { font-size: 0.82rem; color: var(--text-3); margin-bottom: 1.5rem; min-height: 1.2rem; }

    .plan-desc {
      font-size: 0.9rem; color: var(--text-3);
      margin-bottom: 1.5rem; line-height: 1.6;
      padding-bottom: 1.5rem; border-bottom: 1px solid var(--border);
    }

    .plan-features { list-style: none; margin-bottom: 2rem; }
    .plan-features li {
      display: flex; align-items: flex-start; gap: 0.75rem;
      padding: 0.5rem 0; font-size: 0.9rem; color: var(--text-2);
      border-bottom: 1px solid var(--border);
    }
    .plan-features li:last-child { border-bottom: none; }
    .plan-features .check { color: var(--success); font-size: 0.9rem; flex-shrink: 0; margin-top: 0.1rem; }
    .plan-features .cross { color: var(--muted); font-size: 0.9rem; flex-shrink: 0; margin-top: 0.1rem; }
    .plan-features .muted { color: var(--text-3); }

    .plan-cta {
      width: 100%; padding: 0.85rem;
      border-radius: 12px; border: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700; font-size: 0.95rem;
      cursor: pointer; transition: all 0.2s;
    }
    .cta-free {
      background: var(--card-2); color: var(--text-2);
      border: 1.5px solid var(--border-2);
    }
    .cta-free:hover { border-color: var(--accent); color: var(--accent); }
    .cta-pro {
      background: var(--accent); color: #fff;
      box-shadow: 0 4px 16px var(--accent-glow);
    }
    .cta-pro:hover { filter: brightness(1.1); transform: translateY(-1px); }
    .cta-enterprise {
      background: linear-gradient(135deg, #1e3a8a, #1d4ed8);
      color: #fff;
    }
    .cta-enterprise:hover { filter: brightness(1.1); transform: translateY(-1px); }

    /* AD SECTION */
    .ad-section {
      max-width: 1100px; margin: 0 auto 5rem; padding: 0 2rem;
    }
    .ad-section-title {
      text-align: center; margin-bottom: 2rem;
    }
    .ad-section-title h2 { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .ad-section-title p { color: var(--text-3); font-size: 0.95rem; }

    .ad-formats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.2rem;
    }
    .ad-format-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 16px; padding: 1.5rem;
      transition: all 0.2s;
    }
    .ad-format-card:hover { border-color: var(--border-2); transform: translateY(-2px); }
    .ad-format-icon { font-size: 2rem; margin-bottom: 0.75rem; }
    .ad-format-card h3 { font-size: 1rem; margin-bottom: 0.4rem; }
    .ad-format-card p { font-size: 0.85rem; color: var(--text-3); line-height: 1.6; }
    .ad-format-price {
      margin-top: 1rem; font-family: 'JetBrains Mono', monospace;
      font-size: 0.82rem; color: var(--accent); font-weight: 600;
    }

    /* FAQ */
    .faq-section {
      max-width: 720px; margin: 0 auto 5rem; padding: 0 2rem;
    }
    .faq-title { text-align: center; margin-bottom: 2rem; }
    .faq-title h2 { font-size: 1.8rem; margin-bottom: 0.5rem; }
    .faq-title p { color: var(--text-3); }
    .faq-item {
      border-bottom: 1px solid var(--border);
      padding: 1.2rem 0; cursor: pointer;
    }
    .faq-question {
      display: flex; justify-content: space-between;
      align-items: center; font-weight: 600;
      font-size: 0.95rem; color: var(--text);
    }
    .faq-answer {
      font-size: 0.9rem; color: var(--text-3);
      line-height: 1.7; margin-top: 0.75rem;
      display: none;
    }
    .faq-answer.open { display: block; }
    .faq-icon { color: var(--accent); font-size: 1.2rem; transition: transform 0.2s; }
    .faq-icon.open { transform: rotate(45deg); }
  </style>
</head>
<body>

<%- include('_nav', { active: 'pricing' }) %>

<!-- PRICING HERO -->
<div class="pricing-hero">
  <p class="pricing-eyebrow">Simple, Transparent Pricing</p>
  <h1>Invert in Yours <span>IP Intelligence</span></h1>
  <p>From individual inventors to enterprise legal teams — InnovaShield scales with you.</p>

  <!-- BILLING TOGGLE -->
  <div class="billing-toggle" onclick="toggleBilling()">
    <span id="monthly-label" class="active">Monthly</span>
    <div class="toggle-switch" id="billingToggle"></div>
    <span id="yearly-label">Yearly</span>
    <span class="save-badge" id="saveBadge" style="display:none;">Save 20%</span>
  </div>
</div>

<!-- PLANS -->
<div class="plans-grid">

  <!-- FREE -->
  <div class="plan-card fade-up">
    <div class="plan-name">Free</div>
    <div class="plan-price">
      <span class="price-currency">R</span>
      <span class="price-amount">0</span>
      <span class="price-period">/mo</span>
    </div>
    <div class="price-annual">&nbsp;</div>
    <div class="plan-desc">Perfect for individuals exploring patent data and IP basics.</div>
    <ul class="plan-features">
      <li><span class="check">✓</span> Search patents & trademarks</li>
      <li><span class="check">✓</span> View patent details</li>
      <li><span class="check">✓</span> Watchlist — up to 5 items</li>
      <li><span class="check">✓</span> Basic expiry alerts</li>
      <li><span class="cross">✗</span> <span class="muted">AI Trend insights</span></li>
      <li><span class="cross">✗</span> <span class="muted">Export reports</span></li>
      <li><span class="cross">✗</span> <span class="muted">API access</span></li>
      <li><span class="cross">✗</span> <span class="muted">Ads shown</span></li>
    </ul>
    <button class="plan-cta cta-free">Get Started Free</button>
  </div>

  <!-- PRO -->
  <div class="plan-card popular fade-up-1">
    <div class="plan-name">Pro</div>
    <div class="plan-price">
      <span class="price-currency">R</span>
      <span class="price-amount" id="pro-price">15</span>
      <span class="price-period">/mo</span>
    </div>
    <div class="price-annual" id="pro-annual">&nbsp;</div>
    <div class="plan-desc">For IP professionals, attorneys and serious inventors who need full access.</div>
    <ul class="plan-features">
      <li><span class="check">✓</span> Everything in Free</li>
      <li><span class="check">✓</span> Unlimited watchlist</li>
      <li><span class="check">✓</span> Full AI trend insights</li>
      <li><span class="check">✓</span> Export to PDF & CSV</li>
      <li><span class="check">✓</span> Advanced filters & search</li>
      <li><span class="check">✓</span> Email expiry alerts</li>
      <li><span class="check">✓</span> No ads</li>
      <li><span class="cross">✗</span> <span class="muted">API access</span></li>
    </ul>
    <button class="plan-cta cta-pro">Start Pro Trial</button>
  </div>

  <!-- ENTERPRISE -->
  <div class="plan-card fade-up-2">
    <div class="plan-name">Enterprise</div>
    <div class="plan-price">
      <span class="price-currency">R</span>
      <span class="price-amount" id="ent-price">49</span>
      <span class="price-period">/mo</span>
    </div>
    <div class="price-annual" id="ent-annual">&nbsp;</div>
    <div class="plan-desc">For law firms, corporations and teams managing large IP portfolios.</div>
    <ul class="plan-features">
      <li><span class="check">✓</span> Everything in Pro</li>
      <li><span class="check">✓</span> Full API access</li>
      <li><span class="check">✓</span> Team accounts (up to 20)</li>
      <li><span class="check">✓</span> Custom industry reports</li>
       <li><span class="check">✓</span> Priority support</li>
       <li><span class="check">✓</span> USPTO live sync</li>
       <li><span class="check">✓</span> White-label option</li>
      <li><span class="check">✓</span> SLA guarantee</li>
    </ul>
    <button class="plan-cta cta-enterprise">Contact Sales</button>
  </div>

</div>

<!-- AD REVENUE SECTION -->
<div class="ad-section">
  <div class="ad-section-title">
    <h2>Advertising on InnovaShield</h2>
    <p>Reach IP professionals, inventors, attorneys and investors at the point of decision.</p>
  </div>
  <div class="ad-formats">
    <div class="ad-format-card fade-up">
      <div class="ad-format-icon">🎯</div>
      <h3>Sponsored Results</h3>
      <p>Your IP services appear at the top of patent search results — reaching users actively searching your industry.</p>
      <div class="ad-format-price">From R299/month</div>
    </div>
    <div class="ad-format-card fade-up-1">
      <div class="ad-format-icon">📊</div>
      <h3>Trend Report Ads</h3>
      <p>Banner placements inside AI trend reports — seen by decision-makers researching market opportunities.</p>
      <div class="ad-format-price">From R199/month</div>
    </div>
    <div class="ad-format-card fade-up-2">
      <div class="ad-format-icon">📧</div>
      <h3>Alert Email Sponsorship</h3>
      <p>Sponsor our weekly patent expiry alert emails sent to thousands of IP professionals.</p>
      <div class="ad-format-price">From R149/month</div>
    </div>
    <div class="ad-format-card fade-up-3">
      <div class="ad-format-icon">🤝</div>
      <h3>API Partner Program</h3>
      <p>Integrate your legal or IP tools with InnovaShield's API and reach enterprise clients directly.</p>
      <div class="ad-format-price">Custom pricing</div>
    </div>
  </div>
</div>

<!-- FAQ -->
<div class="faq-section">
  <div class="faq-title">
    <h2>Frequently Asked Questions</h2>
    <p>Everything you need to know about InnovaShield pricing.</p>
  </div>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-question">
      Can I switch plans at any time?
      <span class="faq-icon">+</span>
    </div>
    <div class="faq-answer">Yes — you can upgrade or downgrade your plan at any time. Changes take effect immediately and are prorated to your billing cycle.</div>
  </div>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-question">
      What happens to my watchlist if I downgrade to Free?
      <span class="faq-icon">+</span>
    </div>
    <div class="faq-answer">Your watchlist items are preserved but only the first 5 will be active. The rest are archived and restored when you upgrade again.</div>
  </div>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-question">
      Does the Free plan show ads?
      <span class="faq-icon">+</span>
    </div>
    <div class="faq-answer">Yes — the Free plan is supported by relevant ads from legal services, IP attorneys and patent tools. Pro and Enterprise plans are completely ad-free.</div>
  </div>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-question">
      Is there a trial period for Pro?
      <span class="faq-icon">+</span>
    </div>
    <div class="faq-answer">Yes — Pro comes with a 14-day free trial. No credit card required to start.</div>
  </div>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-question">
      How does API access work on Enterprise?
      <span class="faq-icon">+</span>
    </div>
    <div class="faq-answer">Enterprise clients get full REST API access with rate limits up to 10,000 requests/day, dedicated API keys, and webhook support for real-time patent change notifications.</div>
  </div>
</div>

<div class="footer">
  ⚡ InnovaShield — Patent & Trademark Intelligence Platform · Auto-sync running every 24hrs
</div>

<script>
  (function(){
    const t = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', t);
  })();

  function toggleTheme() {
    const curr = document.documentElement.getAttribute('data-theme');
    const next = curr === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    document.querySelector('.theme-toggle').textContent = next === 'dark' ? '◑' : '●';
  }

  document.addEventListener('DOMContentLoaded', () => {
    const t = localStorage.getItem('theme') || 'dark';
    const btn = document.querySelector('.theme-toggle');
    if (btn) btn.textContent = t === 'dark' ? '◑' : '●';
  });

  // BILLING TOGGLE
  let isYearly = false;
  function toggleBilling() {
    isYearly = !isYearly;
    const toggle = document.getElementById('billingToggle');
    const monthly = document.getElementById('monthly-label');
    const yearly = document.getElementById('yearly-label');
    const saveBadge = document.getElementById('saveBadge');

    toggle.classList.toggle('yearly', isYearly);
    monthly.classList.toggle('active', !isYearly);
    yearly.classList.toggle('active', isYearly);
    saveBadge.style.display = isYearly ? 'inline' : 'none';

    document.getElementById('pro-price').textContent = isYearly ? '7' : '15';
    document.getElementById('pro-annual').textContent = isYearly ? 'Billed R84/year' : '';
    document.getElementById('ent-price').textContent = isYearly ? '39' : '49';
    document.getElementById('ent-annual').textContent = isYearly ? 'Billed R468/year' : '';
  }

  // FAQ
  function toggleFaq(item) {
    const answer = item.querySelector('.faq-answer');
    const icon = item.querySelector('.faq-icon');
    answer.classList.toggle('open');
    icon.classList.toggle('open');
  }
</script>

</body>
</html>