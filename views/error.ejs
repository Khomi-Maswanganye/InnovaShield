<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>InnovaShield – Error</title>
  <link rel="stylesheet" href="/style.css"/>
  <script>(function(){ document.documentElement.setAttribute('data-theme', localStorage.getItem('theme')||'dark'); })();</script>
</head>
<body>
<% if (locals.currentUser) { %><div class="page-bg"></div><% } %>
<% if (locals.currentUser) { %><%- include('_nav', { active: '' }) %><% } %>
<div class="container" style="text-align:center; padding-top:4rem;">
  <div style="font-size:3rem; margin-bottom:1rem;">⚠️</div>
  <h1 style="margin-bottom:0.5rem;">Something went wrong</h1>
  <p style="color:var(--text-3); margin-bottom:2rem;"><%= message || 'An unexpected error occurred.' %></p>
  <a href="/" class="btn btn-primary">Go Home</a>
  <a href="javascript:history.back()" class="btn btn-secondary" style="margin-left:0.5rem;">Go Back</a>
</div>
</body>
</html>