# InnovaShield Environment Configuration
# Copy this file to .env and fill in your values

# MySQL Database Configuration (defaults match local dev setup)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=innovashield

# Session secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Default admin account created on first run (change immediately after first login)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@innovashield.com
ADMIN_PASSWORD=change-me-on-first-login
